<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AddShowActivity">

    <!-- Üst Yarım: Arama Çubuğu, Tarih Seçimi, Puanlama Barı -->
    <LinearLayout
        android:id="@+id/upper_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:weightSum="3">

        <!-- Arama Çubuğu -->
        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/show_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Dizi Adı"
            android:padding="10dp"/>

        <!-- Başlangıç Tarihi: Gün, Ay, Yıl -->
        <TextView
            android:id="@+id/start_date_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Başlangıç Tarihi"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:id="@+id/start_date_layout"
            android:layout_width="400dp"
            android:layout_height="66dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:weightSum="3">

            <!-- Gün Spinner -->
            <Spinner
                android:id="@+id/start_day_spinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <!-- Ay Spinner -->
            <Spinner
                android:id="@+id/start_month_spinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <!-- Yıl Spinner -->
            <Spinner
                android:id="@+id/start_year_spinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- Bitiş Tarihi: Gün, Ay, Yıl -->
        <TextView
            android:id="@+id/end_date_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Bitiş Tarihi"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:id="@+id/end_date_layout"
            android:layout_width="400dp"
            android:layout_height="66dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:weightSum="3">

            <!-- Gün Spinner -->
            <Spinner
                android:id="@+id/end_day_spinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <!-- Ay Spinner -->
            <Spinner
                android:id="@+id/end_month_spinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <!-- Yıl Spinner -->
            <Spinner
                android:id="@+id/end_year_spinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- Puanlama Barı -->
        <SeekBar
            android:id="@+id/rating_bar"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginTop="24dp"
            android:max="10"
            android:progress="0" />
    </LinearLayout>

    <!-- Alt Yarım: Metin Kutusu ve Spoiler Checkbox -->
    <RelativeLayout
        android:id="@+id/lower_layout"
        android:layout_width="410dp"
        android:layout_height="479dp"
        android:layout_marginTop="20dp"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/upper_layout"
        tools:ignore="ExtraText">

        <!-- Metin Kutusu -->
        <EditText
            android:id="@+id/comment_box"
            android:layout_width="394dp"
            android:layout_height="457dp"
            android:hint="Yorumunuzu yazın"
            android:padding="10dp" />

        <!-- Spoiler Checkbox -->
        <CheckBox
            android:id="@+id/spoiler_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="10dp"
            android:text="Spoiler içeriyor"></CheckBox>
    </RelativeLayout>

    <!-- Paylaş Butonu -->
    <Button
        android:id="@+id/share_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Paylaş"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/lower_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
