<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Summer light blue gradient -->
    <item>
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#FFFFFF" 
                android:endColor="#D1EAFF"
                android:type="linear" />
        </shape>
    </item>
    <!-- Extremely subtle watermark (0.5%) for the main 5 pages -->
    <item android:alpha="0.005">
        <bitmap
            android:src="@drawable/welcome_bg"
            android:gravity="center"
            android:scaleType="centerCrop" />
    </item>
</layer-list>
